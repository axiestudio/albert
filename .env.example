# ═══════════════════════════════════════════════════════════════════════════════
# Albert Law Agent — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to:
#   backend/.dev.vars     (Wrangler reads .dev.vars for Workers)
#
# Frontend provider keys now live in Albert's Settings UI and are stored
# locally in the browser instead of in frontend env files.
#
# Or use the interactive CLI:
#   bun run setup
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────────────────────────

# Google Vertex AI Express Mode API Key
# Get one free at: https://aistudio.google.com/apikey
# Powers the default Gemini models (gemini-2.5-flash, gemini-2.5-pro, etc.)
GOOGLE_API_KEY=your_google_api_key_here

# ─── Required for Vectorize (semantic law search) ────────────────────────────

# Cloudflare Account ID
# Find at: https://dash.cloudflare.com → Workers & Pages → Overview (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare API Token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: "Vectorize: Edit" + "Workers AI: Run"
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ─── Optional — Alternative LLM Providers ────────────────────────────────────

# OpenAI (GPT-4o, o3, etc.)
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Vertex AI Partner Models (Claude/Mistral/DeepSeek via Google Cloud)
# VERTEX_PROJECT_ID=your_gcp_project_id

# ─── Optional — Cloudflare AI Gateway ────────────────────────────────────────
# Adds analytics, caching, and rate limiting to LLM requests.
# CLOUDFLARE_GATEWAY_ACCOUNT_ID=your_account_id
# CLOUDFLARE_GATEWAY_NAME=your_gateway_name
# CLOUDFLARE_GATEWAY_TOKEN=your_gateway_token

# ─── Optional — Browser Use Cloud API ────────────────────────────────────────
# Enables the web research tool (deep web browsing).
# Get a key at: https://cloud.browser-use.com
# BROWSER_USE_API_KEY=your_browser_use_key
