{
  "name": "law-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 3000",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && echo _worker.js > dist/.assetsignore && wrangler deploy",
    "deploy:prod": "astro build && echo _worker.js > dist/.assetsignore && wrangler deploy --env production",
    "deploy:test": "astro build && echo _worker.js > dist/.assetsignore && wrangler deploy --env testing",
    "deploy:staging": "astro build && echo _worker.js > dist/.assetsignore && wrangler deploy --env staging",
    "deploy:prod:skip-build": "wrangler deploy --env production",
    "deploy:test:skip-build": "wrangler deploy --env testing",
    "check-types": "astro check && tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "sfs:download": "bun ../scripts/download-sfs-index.ts",
    "sfs:download:force": "bun ../scripts/download-sfs-index.ts --force",
    "vectorize:deploy": "bun ../scripts/deploy-vectorize.ts",
    "vectorize:deploy:dry": "bun ../scripts/deploy-vectorize.ts --dry-run",
    "vectorize:status": "bun ../scripts/deploy-vectorize.ts --status",
    "vectorize:delete": "bun ../scripts/deploy-vectorize.ts --delete",
    "vectorize:ingest": "bun ../scripts/ingest-sfs-vectorize.ts",
    "vectorize:ingest:dry": "bun ../scripts/ingest-sfs-vectorize.ts --dry-run",
    "vectorize:full": "bun ../scripts/download-sfs-index.ts --force && bun ../scripts/deploy-vectorize.ts && bun ../scripts/ingest-sfs-vectorize.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/react": "^3.0.136",
    "@assistant-ui/react": "^0.12.19",
    "@assistant-ui/react-ai-sdk": "^1.3.14",
    "@assistant-ui/react-markdown": "^0.12.6",
    "@assistant-ui/react-streamdown": "^0.1.7",
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/react": "^4.4.2",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "ai": "^6.0.130",
    "astro": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.41",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.63.0"
  }
}
