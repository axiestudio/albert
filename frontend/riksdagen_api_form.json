    "base_url": "https://data.riksdagen.se/dokumentlista/",
    "parameters": {
      "sok": {
        "label": "Sökord (Search term)",
        "type": "text",
        "param": "sok"
      },
      "doktyp": {
        "label": "Dokumenttyp (Document type)",
        "type": "select",
        "param": "doktyp",
        "option_count": 85,
        "options_sample": [
          {
            "value": "kam-ad",
            "text": "Aktuell debatt"
          },
          {
            "value": "kam-al",
            "text": "Allmänpolitisk debatt"
          },
          {
            "value": "kam-av",
            "text": "Avslutning"
          },
          {
            "value": "kam-at",
            "text": "Avtackning"
          },
          {
            "value": "kam-vo",
            "text": "Beslut"
          },
          {
            "value": "kal-be",
            "text": "Besök"
          },
          {
            "value": "bet",
            "text": "Betänkande"
          },
          {
            "value": "kam-bd",
            "text": "Bordläggningsdebatt"
          },
          {
            "value": "kam-bp",
            "text": "Bordläggningsplenum"
          },
          {
            "value": "kam-bu",
            "text": "Budgetdebatt"
          },
          {
            "value": "kam-dv",
            "text": "Debatt om vårpropositionen"
          },
          {
            "value": "ds",
            "text": "Departementsserien"
          },
          {
            "value": "kam-eu",
            "text": "EU-debatt"
          },
          {
            "value": "kom",
            "text": "EU-förslag"
          },
          {
            "value": "eundok",
            "text": "EU-nämndens dokument"
          },
          {
            "value": "eprotokoll",
            "text": "EU-nämndens protokoll"
          }
        ],
        "note": "85 total document types available including motions, propositions, protocols, debates, EU documents, etc."
      },
      "rm": {
        "label": "Riksmöte (Parliamentary session)",
        "type": "text",
        "param": "rm"
      },
      "from": {
        "label": "Datum (Date from)",
        "type": "text",
        "param": "from",
        "format": "YYYY-MM-DD"
      },
      "tom": {
        "label": "T.o.m. (Date to)",
        "type": "text",
        "param": "tom",
        "format": "YYYY-MM-DD",
        "example": "2005-11-11"
      },
      "ts": {
        "label": "Systemdatum (System date)",
        "type": "text",
        "param": "ts"
      },
      "bet": {
        "label": "Beteckning (Designation)",
        "type": "text",
        "param": "bet"
      },
      "tempbet": {
        "label": "Tempbet (Temp designation)",
        "type": "text",
        "param": "tempbet"
      },
      "nr": {
        "label": "Nummer (Number)",
        "type": "text",
        "param": "nr"
      },
      "org": {
        "label": "Utskott/organ (Committee/body)",
        "type": "select",
        "param": "org",
        "option_count": 63,
        "options_sample": [
          "Arbetsmarknadsutskottet (AU)",
          "Bostadsutskottet (BoU)",
          "Civilutskottet (CU)"
