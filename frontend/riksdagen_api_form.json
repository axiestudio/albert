        "options": [
          {
            "value": "S",
            "text": "Socialdemokraterna"
          },
          {
            "value": "M",
            "text": "Moderata samlingspartiet"
          },
          {
            "value": "L",
            "text": "Liberalerna"
          },
          {
            "value": "KD",
            "text": "Kristdemokraterna"
          },
          {
            "value": "V",
            "text": "Vänsterpartiet"
          },
          {
            "value": "SD",
            "text": "Sverigedemokraterna"
          },
          {
            "value": "C",
            "text": "Centerpartiet"
          },
          {
            "value": "MP",
            "text": "Miljöpartiet de gröna"
          },
          {
            "value": "NYD",
            "text": "Ny demokrati"
          },
          {
            "value": "-",
            "text": "partilösa/m.m."
          }
        ]
      },
      "avd": {
        "label": "Avdelning (Section)",
        "type": "select",
        "param": "avd",
        "option_count": 7,
        "options_sample": [
          "alla",
          "Dokument",
          "Webb-tv",
          "Kalender"
        ]
      },
      "webbtv": {
        "label": "Webb-tv",
        "type": "text",
        "param": "webbtv",
        "note": "Value 1 to filter"
      },
      "talare": {
        "label": "Talare (Speaker)",
        "type": "text",
        "param": "talare"
      },
      "exakt": {
        "label": "Exakt matchning (Exact match)",
        "type": "text",
        "param": "exakt",
        "note": "Value 1 for exact"
      },
      "planering": {
        "label": "Planering (Planning)",
        "type": "text",
        "param": "planering"
      },
      "facetter": {
        "label": "Facetter (Facets)",
        "type": "text",
        "param": "facets",
        "note": "Values 0-4"
      },
      "sort": {
        "label": "Sortering (Sorting)",
        "type": "select",
        "param": "sort",
        "option_count": 10,
        "options_sample": [
          "Relevans",
          "Datum",
          "systemdatum",
          "Beteckning"
        ]
      },
      "sortorder": {
        "label": "Ordning (Order)",
        "type": "select",
        "param": "sortorder",
        "options": [
          {
            "value": "desc",
            "text": "Fallande (desc)"
          },
          {
            "value": "asc",
            "text": "Stigande (asc)"
          }
        ]
      },
      "rapport": {
        "label": "Rapporter (Reports)",
        "type": "select",
        "param": "rapport",
        "options_sample": [
          "motionstid",
          "Inkomna förslag"
        ]
      },
      "utformat": {
        "label": "Utformat (Output format)",
        "type": "select",
        "param": "utformat",
        "option_count": 9,
        "options_sample": [
          "RSS",
          "HTML - webbsida",
          "XML"
        ]
      }
    },
