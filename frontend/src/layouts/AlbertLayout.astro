---
import "../styles.css";

const title = "ALBERT | Svensk rättsanalys med källstöd";
const description =
  "Albert förklarar svensk rätt i klartext med spårade rättskällor, reservationer och guidat forskningsstöd för svenska juridiska frågor.";
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1f1f23" />
    <meta property="og:title" content="ALBERT | Svensk rätt i klartext" />
    <meta
      property="og:description"
      content="AI-stödd svensk rättsanalys med spårade källor från lag, förarbeten och kompletterande forskning."
    />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:image" content="/albert-icon.svg" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="ALBERT | Svensk rätt i klartext" />
    <meta
      name="twitter:description"
      content="Albert hjälper dig förstå svensk rätt med spårade källor, reservationer och guidat forskningsstöd."
    />
    <link rel="icon" type="image/svg+xml" href="/albert-icon.svg" />
    <link rel="apple-touch-icon" href="/albert-icon.svg" />
  </head>
  <body class="bg-background text-foreground">
    <slot />
  </body>
</html>